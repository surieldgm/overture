# Overture environment variables
#
# Copy this file to `.env` and fill in real values for your workspace.
# Never commit `.env` — it is excluded by .gitignore.
#
# Each variable below is grouped by which capability needs it. Variables
# marked SECRET must come from a trusted source and rotate on suspected
# leak. Variables marked WORKSPACE-SPECIFIC are not strictly secret but
# bind a checkout to a particular Linear workspace and should match your
# team's setup.

# -- Linear export (required for `overture export` against a real workspace)
# LINEAR_API_KEY: SECRET. Personal API key from https://linear.app/settings/api
LINEAR_API_KEY=

# LINEAR_TEAM_ID: WORKSPACE-SPECIFIC. UUID of the Linear team that owns the
# project Overture posts into. Can be supplied via `--team-id` instead.
LINEAR_TEAM_ID=

# LINEAR_PROJECT_ID: WORKSPACE-SPECIFIC, optional. Pin exports to a Linear
# project. Can be supplied via `--project-id` instead.
LINEAR_PROJECT_ID=

# -- Shared backend authentication (required when running the multi-user host)
# OVERTURE_AUTH_SECRET: SECRET. Long random string used to sign magic-link
# tokens. Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
OVERTURE_AUTH_SECRET=

# OVERTURE_MAGIC_LINK_WEBHOOK_URL: Endpoint that delivers magic-link emails to
# operators. When unset, magic links are written to OVERTURE_MAGIC_LINK_OUTBOX
# below for local testing.
OVERTURE_MAGIC_LINK_WEBHOOK_URL=

# OVERTURE_MAGIC_LINK_OUTBOX: Local directory or file path that captures
# magic links during development. Use only when the webhook URL above is unset.
OVERTURE_MAGIC_LINK_OUTBOX=

# -- Linear webhook ingest (required when receiving Linear status changes)
# OVERTURE_LINEAR_WEBHOOK_SECRET: SECRET. Shared secret configured in Linear's
# webhook settings. Used to verify HMAC signatures on incoming webhook payloads.
OVERTURE_LINEAR_WEBHOOK_SECRET=

# -- Workspace and runtime (optional)
# OVERTURE_HOME: Root directory for `.overture/` runtime state. Defaults to the
# current working directory. Set this when running outside the repo root.
OVERTURE_HOME=

# OVERTURE_CODEX_EXECUTABLE: Path to the local `codex` CLI used by the LLM-suggested
# research adapter. Defaults to `codex` on PATH.
OVERTURE_CODEX_EXECUTABLE=

# OVERTURE_LLM_CLIENT: Set to `fake` to bypass the Codex CLI and use a deterministic
# stub. Used by tests and human smoke runs without Codex installed.
OVERTURE_LLM_CLIENT=

# -- Example scripts (developer convenience, not required)
# OVERTURE_TWO_INTAKE_LOOP_DIR: Override directory for the two-intake validation
# example script. Used only by `examples/validate_two_intake_loop.py`.
OVERTURE_TWO_INTAKE_LOOP_DIR=
